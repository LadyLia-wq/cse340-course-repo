<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p>Name: <%= name %></p>
    <p>Username: <%= email %></p>

    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/users">View Registered Users</a></p>
    <% } %>

    <section>
        <h2>My Volunteer Projects</h2>

            <% if (volunteerProjects.length > 0) { %>
                <ul>
                    <% volunteerProjects.forEach(project => { %>
                        <li>
                            <a href="/project/<%= project.project_id %>">
                                <strong><%= project.title %></strong>
                            </a>

                            - <%= project.organization_name %>
                            <br>

                            <%= new Date(project.project_date).toLocaleDateString('en-US', {
                                year: 'numeric',
                                month: 'long',
                                day: 'numeric'
                            }) %>

                            <form action="/project/<%= project.project_id %>/remove-volunteer" method="POST">
                                <button type="submit">Remove</button>
                            </form>
                        </li>
                    <% }) %>
                </ul>
        <% } else { %>
            <p>You have not volunteered for any projects yet.</p>
        <% } %>
    </section>
</main>

<%- include('partials/footer') %>