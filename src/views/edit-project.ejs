<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <form action="/edit-project/<%= project.project_id %>" method="POST">
        <div>
            <label for="title">Project Title</label>
            <input
                type="text"
                id="title"
                name="title"
                value="<%= project.title %>"
                required
            >
        </div>

        <div>
            <label for="description">Description</label>
            <textarea
                id="description"
                name="description"
                required
            ><%= project.description %></textarea>
        </div>

        <div>
            <label for="location">Location</label>
            <input
                type="text"
                id="location"
                name="location"
                value="<%= project.location %>"
                required
            >
        </div>

        <div>
            <label for="project_date">Project Date</label>
            <input
                type="date"
                id="project_date"
                name="project_date"
                value="<%= project.date ? project.date.toISOString().split('T')[0] : '' %>"
                required
            >
        </div>

        <div>
            <label for="organizationId">Organization</label>
            <select id="organizationId" name="organizationId" required>
                <% organizations.forEach((organization) => { %>
                    <option
                        value="<%= organization.organization_id %>"
                        <%= organization.organization_id === project.organization_id ? 'selected' : '' %>
                    >
                        <%= organization.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <button type="submit">Update Project</button>
    </form>
</main>

<%- include('partials/footer') %>