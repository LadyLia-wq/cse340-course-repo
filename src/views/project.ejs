<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>

    <p>
        <strong>Description:</strong>
        <%= project.description %>
    </p>

    <p>
        <strong>Date:</strong>
        <%= new Date(project.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        }) %>
    </p>

    <p>
        <strong>Location:</strong>
        <%= project.location %>
    </p>

    <p>
        <strong>Organization:</strong>

        <a href="/organization/<%= project.organization_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <section>
        <h2>Categories</h2>

        <% if (categories.length > 0) { %>
            <div class="category-tags">
                <% categories.forEach(category => { %>
                    <a href="/category/<%= category.category_id %>">
                        <%= category.name %>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <p>No categories assigned to this project.</p>
        <% } %>

        <div class="button-group">
            <% if (user && user.role_name === 'admin') { %>
                <a href="/edit-project/<%= project.project_id %>">
                    Edit Project
                </a>
            <% } %>

            <% if (user && user.role_name === 'admin') { %>
                <a href="/assign-categories/<%= project.project_id %>">
                    Edit Project Categories
                </a>
            <% } %>
        </div>
    </section>

    <% if (user) { %>
    <section>
        <h2>Volunteer</h2>

        <% if (volunteering) { %>
            <p>You are volunteering for this project.</p>

            <form action="/project/<%= project.project_id %>/remove-volunteer" method="POST">
                <button type="submit">Remove Myself as Volunteer</button>
            </form>
        <% } else { %>
            <form action="/project/<%= project.project_id %>/volunteer" method="POST">
                <button type="submit">Volunteer for this Project</button>
            </form>
        <% } %>
    </section>
<% } %>
</main>

<%- include('partials/footer') %>