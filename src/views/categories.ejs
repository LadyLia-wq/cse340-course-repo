<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2>Explore our categories</h2>
    <ul>
        <% categories.forEach(category => { %>
            <li>
                <a href="/category/<%= category.category_id %>">
                    <%= category.name %></li>
                </a>            
        <% }) %>
    </ul>
   
</main>
<%- include('partials/footer') %>

